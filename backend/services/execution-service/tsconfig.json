{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "../..",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
    "baseUrl": "./",
    "paths": {
      "@naas/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*.ts", "../../packages/shared/src/**/*.ts"]
}
